# ============================================================
# FutureSelf Server 环境变量模板
# 复制此文件为 .env 并填入真实凭据
# ⚠️ .env 绝不提交至 Git
# ============================================================

# ---- 服务端口 ----
PORT=3000

# ---- MongoDB ----
MONGODB_URI=mongodb://root:password@host:27017
MONGODB_DB_NAME=futureself

# ---- DeepSeek API ----
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---- AES 加密密钥（32字节 base64） ----
AES_ENCRYPTION_KEY=your-32-byte-base64-encoded-key-here

# ---- CORS 允许的前端地址（多个用逗号分隔） ----
# 本地开发：http://localhost:5173
# Vercel 生产：https://你的项目名.vercel.app
CORS_ORIGIN=http://localhost:5173,http://localhost:4173
