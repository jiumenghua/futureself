# ============================================================
# FutureSelf 前端 — 生产环境变量
# 部署到 Vercel 时，在 Vercel Dashboard 设置此变量覆盖本地文件
# VITE_API_BASE_URL 格式：https://你的Render域名
# 示例：https://futureself-api.onrender.com
# ============================================================
VITE_API_BASE_URL=https://YOUR_RENDER_APP.onrender.com
